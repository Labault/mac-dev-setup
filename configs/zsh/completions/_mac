#compdef mac

local -a commands options profiles

commands=(
  setup
)

options=(
  --profile
  --dry-run
)

profiles=(
  full
  minimal
)

if (( CURRENT == 2 )); then
  compadd -a commands
  return
fi

case "${words[2]}" in
  setup)
    if [[ "${words[CURRENT-1]}" == "--profile" || "${words[CURRENT-1]}" == --profile=* ]]; then
      compadd -a profiles
      return
    fi

    compadd -a options
    ;;
esac
